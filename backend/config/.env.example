# Copy to config/.env for local development (never commit real secrets)

# If another app already uses 8000 (common), set e.g. 8001 and match REACT_APP_API_URL on the frontend.
PORT=8000
NODE_ENV=development

# Mongoose connection string (code uses DB_URL or MONGO_URI)
# Local:
# DB_URL=mongodb://127.0.0.1:27017/eshop
# Atlas (example: project E-Shop 6774ec55a095ed3ee572dbc0, host cluster0.iugcr.mongodb.net):
# DB_URL=mongodb+srv://USER:PASSWORD@cluster0.iugcr.mongodb.net/eshop?retryWrites=true&w=majority
DB_URL=mongodb://127.0.0.1:27017/eshop
MONGO_URI=mongodb://127.0.0.1:27017/eshop

JWT_SECRET_KEY=change-me-long-random-string
ACTIVATION_SECRET=change-me-activation-secret

# Comma-separated browser origins allowed for CORS + email activation links (first entry used for links)
FRONTEND_URL=http://localhost:3000

# Cloudinary
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Stripe (use real keys only in config/.env — do not paste into the repo)
# STRIPE_PUBLISHABLE_KEY: pk_test_... or pk_live_... (returned by GET /payment/stripeapikey)
# STRIPE_API_KEY is accepted as a fallback name for the publishable key only.
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=

# Email (if using nodemailer flows)
SMTP_HOST=
SMTP_PORT=
SMTP_MAIL=
SMTP_PASSWORD=

LOG_LEVEL=info

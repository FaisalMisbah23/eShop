# Create React App: only variables prefixed with REACT_APP_ are exposed to the browser.

# API origin without trailing slash (no /api/v2 suffix); must match backend PORT
REACT_APP_API_URL=http://localhost:8000

# Socket.IO server origin (no path)
REACT_APP_SOCKET_URL=http://localhost:5000

# Optional PayPal client id (public)
# REACT_APP_PAYPAL_CLIENT_ID=
